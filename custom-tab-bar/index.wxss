.tab-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 110rpx;
  background: #FFFFFF;
  border-top: 1rpx solid rgba(0,0,0,0.06);
  padding-bottom: env(safe-area-inset-bottom);
}
.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  gap: 4rpx;
  padding: 8rpx 0;
}
.tab-icon {
  width: 48rpx;
  height: 48rpx;
}
.tab-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #999999;
}
.tab-item.active .tab-text {
  color: #FF6B6B;
  font-weight: 800;
}
