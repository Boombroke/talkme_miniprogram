/* Shared Style Fragments (Mixins) */
/* Reusable component-level styles imported via app.wxss */

/* ========== Card ========== */
.card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

/* ========== Buttons ========== */
.btn-primary {
  background-color: #4A90D9;
  color: #FFFFFF;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  text-align: center;
  border: none;
  padding: 0 48rpx;
}

.btn-primary::after {
  border: none;
}

.btn-primary-plain {
  background-color: transparent;
  color: #4A90D9;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  text-align: center;
  border: 2rpx solid #4A90D9;
  padding: 0 48rpx;
}

.btn-primary-plain::after {
  border: none;
}

.btn-default {
  background-color: #FFFFFF;
  color: #333333;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  text-align: center;
  border: 2rpx solid #E8E8E8;
  padding: 0 48rpx;
}

.btn-default::after {
  border: none;
}

.btn-block {
  width: 100%;
  display: block;
}

.btn-sm {
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
  padding: 0 32rpx;
  border-radius: 32rpx;
}

/* ========== Input ========== */
.input-default {
  height: 80rpx;
  background-color: #F5F7FA;
  border-radius: 40rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: #333333;
  width: 100%;
}

/* ========== Tags ========== */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  font-size: 22rpx;
  border-radius: 8rpx;
  line-height: 1.6;
}

.tag-primary {
  background-color: #E8F1FB;
  color: #4A90D9;
}

.tag-success {
  background-color: #E6F7E0;
  color: #52C41A;
}

.tag-warning {
  background-color: #FFF7E6;
  color: #FAAD14;
}

/* ========== Divider ========== */
.divider {
  width: 100%;
  height: 1rpx;
  background-color: #E8E8E8;
  margin: 24rpx 0;
}

/* ========== Avatar ========== */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar image {
  width: 100%;
  height: 100%;
}

/* ========== Badge ========== */
.badge {
  display: inline-block;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  font-size: 20rpx;
  color: #FFFFFF;
  background-color: #FF4D4F;
  border-radius: 16rpx;
  text-align: center;
  position: absolute;
  top: -8rpx;
  right: -8rpx;
}

/* ========== Empty State ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
}

.empty-state text {
  font-size: 28rpx;
  color: #999999;
  text-align: center;
}
