/* Design Tokens - CSS Custom Properties */
/* These variables are available globally via @import in app.wxss */
/* AESTHETIC DIRECTION: Warm, playful, and premium (Coral to Orange sunset vibes) */

page {
  /* Color - Primary (Vibrant Coral/Orange) */
  --color-primary: #FF6B6B;
  --color-primary-dark: #EE5253;
  --color-primary-light: #FF9F43;
  --color-primary-lighter: #FFEAA7;
  
  /* 
   * Gradients (Documented as comments since WXSS vars don't parse gradients well in all contexts)
   * --gradient-primary: linear-gradient(135deg, #FF6B6B 0%, #FF9F43 100%);
   * --gradient-secondary: linear-gradient(135deg, #FF9F43 0%, #Feca57 100%);
   * --gradient-free-chat: linear-gradient(135deg, #FF9A9E 0%, #FECFEF 99%, #FECFEF 100%);
   * --gradient-scene: linear-gradient(120deg, #F6D365 0%, #FDA085 100%);
   * --gradient-bg: linear-gradient(180deg, #FFF0E6 0%, #F8F9FA 100%);
   */

  /* Color - Semantic */
  --color-success: #10AC84;
  --color-warning: #FECA57;
  --color-danger: #EE5253;

  /* Color - Text */
  --color-text-primary: #2D3436;
  --color-text-secondary: #636E72;
  --color-text-hint: #B2BEC3;

  /* Color - Background */
  --color-bg-primary: #F8F9FA;
  --color-bg-white: #FFFFFF;
  --color-bg-subtle: #FFF0E6;

  /* Color - Border */
  --color-border: #DFE6E9;

  /* Font Size - Bigger and bolder */
  --font-size-xs: 22rpx;
  --font-size-sm: 26rpx;
  --font-size-md: 30rpx;
  --font-size-lg: 36rpx;
  --font-size-xl: 44rpx;
  --font-size-xxl: 56rpx;

  /* Spacing - Generous */
  --spacing-xs: 12rpx;
  --spacing-sm: 20rpx;
  --spacing-md: 32rpx;
  --spacing-lg: 48rpx;
  --spacing-xl: 64rpx;

  /* Border Radius - Very rounded, friendly */
  --radius-xs: 16rpx;
  --radius-sm: 24rpx;
  --radius-md: 32rpx;
  --radius-lg: 48rpx;
  --radius-round: 50%;
  
  /* Shadows - Soft and deep */
  --shadow-soft: 0 16rpx 40rpx rgba(255, 107, 107, 0.15);
  --shadow-card: 0 20rpx 48rpx rgba(0, 0, 0, 0.04);
}