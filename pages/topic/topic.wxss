/* Topic Challenge Page — Coral Design System */

.topic-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF0E6 0%, #F8F9FA 30%);
  padding: 32rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

/* ========== PICK STAGE ========== */
.pick-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 40rpx;
}

.pick-emoji {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.pick-title {
  font-size: 44rpx;
  font-weight: 900;
  color: #2D3436;
  margin-bottom: 8rpx;
}

.pick-subtitle {
  font-size: 26rpx;
  color: #B2BEC3;
  font-weight: 500;
}

.topic-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-top: 16rpx;
}

.topic-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.topic-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #FF6B6B, #FF9F43);
  border-radius: 3rpx;
}

.topic-card:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.2);
}

.topic-card-emoji {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.topic-card-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #2D3436;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.topic-card-zh {
  font-size: 22rpx;
  color: #B2BEC3;
  margin-bottom: 16rpx;
}

.topic-card-diff {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.diff-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.diff-beginner { background: #10AC84; }
.diff-intermediate { background: #FF9F43; }
.diff-advanced { background: #EE5253; }

.diff-label {
  font-size: 20rpx;
  color: #636E72;
  text-transform: capitalize;
}

/* ========== PREP STAGE ========== */
.stage-prep {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 60rpx;
}

.prep-topic-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  text-align: center;
  width: 100%;
  margin-bottom: 48rpx;
}

.prep-emoji {
  font-size: 72rpx;
  display: block;
  margin-bottom: 20rpx;
}

.prep-topic-text {
  font-size: 36rpx;
  font-weight: 800;
  color: #2D3436;
  display: block;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.prep-topic-zh {
  font-size: 26rpx;
  color: #B2BEC3;
}

.countdown-wrap {
  margin: 32rpx 0;
}

.countdown-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B6B, #FF9F43);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(255, 107, 107, 0.35);
}

.countdown-number {
  font-size: 72rpx;
  font-weight: 900;
  color: #FFFFFF;
  line-height: 1;
}

.countdown-unit {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 600;
}

.prep-hint {
  font-size: 26rpx;
  color: #636E72;
  margin: 24rpx 0 48rpx;
  font-style: italic;
}

.prep-actions {
  width: 100%;
  padding: 0 32rpx;
}

/* ========== RECORDING STAGE ========== */
.stage-recording {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 48rpx;
}

.recording-topic {
  background: rgba(255, 107, 107, 0.08);
  border-radius: 24rpx;
  padding: 20rpx 32rpx;
  margin-bottom: 60rpx;
}

.recording-topic-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #FF6B6B;
}

.mic-wrap {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.mic-pulse-ring {
  position: absolute;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 107, 107, 0.3);
  animation: mic-pulse 2s ease-out infinite;
}

.ring-1 {
  width: 160rpx;
  height: 160rpx;
  animation-delay: 0s;
}

.ring-2 {
  width: 200rpx;
  height: 200rpx;
  animation-delay: 0.5s;
}

.ring-3 {
  width: 240rpx;
  height: 240rpx;
  animation-delay: 1s;
}

@keyframes mic-pulse {
  0% {
    transform: scale(0.8);
    opacity: 1;
  }
  100% {
    transform: scale(1.4);
    opacity: 0;
  }
}

.mic-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #EE5253, #FF6B6B);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(238, 82, 83, 0.4);
  z-index: 2;
}

.mic-icon {
  font-size: 56rpx;
}

.record-countdown-wrap {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.record-countdown-number {
  font-size: 64rpx;
  font-weight: 900;
  color: #EE5253;
}

.record-countdown-label {
  font-size: 28rpx;
  color: #636E72;
  font-weight: 600;
}

.recording-hint {
  font-size: 26rpx;
  color: #636E72;
  margin-bottom: 48rpx;
}

.recording-actions {
  width: 100%;
  padding: 0 32rpx;
}

/* ========== EVALUATING STAGE ========== */
.stage-evaluating {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
}

.evaluating-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.evaluating-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D3436;
}

.evaluating-sub {
  font-size: 24rpx;
  color: #B2BEC3;
}

/* ========== RESULT STAGE ========== */
.stage-result {
  padding-bottom: 48rpx;
}

.result-score-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.result-score-emoji {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.result-score-number {
  font-size: 96rpx;
  font-weight: 900;
  line-height: 1;
  margin-bottom: 8rpx;
}

.result-score-label {
  font-size: 26rpx;
  color: #B2BEC3;
  font-weight: 600;
}

.result-dims-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.dims-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #2D3436;
  display: block;
  margin-bottom: 24rpx;
}

.dim-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.dim-row:last-child {
  margin-bottom: 0;
}

.dim-name {
  font-size: 24rpx;
  color: #636E72;
  font-weight: 600;
  width: 100rpx;
  flex-shrink: 0;
}

.dim-bar-track {
  flex: 1;
  height: 16rpx;
  background: #F0F0F0;
  border-radius: 8rpx;
  overflow: hidden;
}

.dim-bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.8s ease;
}

.dim-val {
  font-size: 26rpx;
  color: #2D3436;
  font-weight: 800;
  width: 56rpx;
  text-align: right;
  flex-shrink: 0;
}

.result-spoken-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.spoken-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2D3436;
  display: block;
  margin-bottom: 16rpx;
}

.spoken-text {
  font-size: 26rpx;
  color: #636E72;
  line-height: 1.7;
  display: block;
  word-break: break-word;
}

.result-feedback-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.feedback-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2D3436;
  display: block;
}

.card-header-flex {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.play-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 107, 107, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
  flex-shrink: 0;
}

.play-btn:active {
  transform: scale(0.9);
  background: rgba(255, 107, 107, 0.2);
}

.play-btn.playing {
  background: rgba(255, 107, 107, 0.2);
  animation: pulse-play 1.5s infinite;
}

@keyframes pulse-play {
  0% { box-shadow: 0 0 0 0 rgba(255, 107, 107, 0.4); }
  70% { box-shadow: 0 0 0 10rpx rgba(255, 107, 107, 0); }
  100% { box-shadow: 0 0 0 0 rgba(255, 107, 107, 0); }
}

.play-icon {
  font-size: 28rpx;
}

.tip-play-btn {
  width: 48rpx;
  height: 48rpx;
  margin-left: 8rpx;
}

.tip-play-btn .play-icon {
  font-size: 24rpx;
}

/* Confetti Animation */
.confetti-container {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  overflow: hidden;
  z-index: 10;
}

.confetti {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  top: -20rpx;
  opacity: 0;
  animation: fall linear forwards;
}

@keyframes fall {
  0% {
    transform: translateY(0) rotate(0deg);
    opacity: 1;
  }
  100% {
    transform: translateY(100vh) rotate(360deg);
    opacity: 0;
  }
}

.feedback-text {
  font-size: 26rpx;
  color: #636E72;
  line-height: 1.7;
  display: block;
}

.result-tips-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2D3436;
  display: block;
  margin-bottom: 20rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-index {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B6B, #FF9F43);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  line-height: 40rpx;
  text-align: center;
}

.tip-text {
  font-size: 26rpx;
  color: #636E72;
  line-height: 1.6;
  flex: 1;
}

.result-encouragement {
  text-align: center;
  padding: 24rpx 0;
}

.encouragement-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #FF6B6B;
}

.result-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 32rpx;
}

/* ========== SHARED BUTTON STYLES ========== */
.btn-ready {
  background: linear-gradient(135deg, #FF6B6B, #FF9F43) !important;
  border: none !important;
  font-weight: 700 !important;
  font-size: 32rpx !important;
  height: 96rpx !important;
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 107, 0.3);
}

.btn-stop {
  background: linear-gradient(135deg, #EE5253, #FF6B6B) !important;
  border: none !important;
  font-weight: 700 !important;
  font-size: 32rpx !important;
  height: 96rpx !important;
  box-shadow: 0 12rpx 32rpx rgba(238, 82, 83, 0.3);
}

.btn-retry {
  background: linear-gradient(135deg, #FF6B6B, #FF9F43) !important;
  border: none !important;
  font-weight: 700 !important;
  font-size: 32rpx !important;
  height: 96rpx !important;
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 107, 0.3);
}

.btn-home {
  border-color: #DFE6E9 !important;
  color: #636E72 !important;
  font-weight: 600 !important;
  font-size: 30rpx !important;
  height: 88rpx !important;
}

.btn-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.btn-icon {
  font-size: 36rpx;
}
