.profile-page {
  min-height: 100vh;
  background: #F8F9FA;
  padding-bottom: 64rpx;
}

/* Header Section */
.header-section {
  position: relative;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF9F43 100%);
  padding: 80rpx 48rpx 140rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(255, 107, 107, 0.3);
  border-bottom-left-radius: 64rpx;
  border-bottom-right-radius: 64rpx;
}

/* ===== 未登录态布局修正 =====
   已登录态：header 用 140rpx 大下 padding 留出空间让 .stats-grid 用 -80rpx margin
   "挂"到 header 底部圆角上。未登录态没有 stats-grid，所以 header padding 不用
   留那么多，菜单直接紧跟 header。 */
.is-guest .header-section {
  padding: 60rpx 48rpx 72rpx;
}
.is-guest .menu-section {
  margin-top: 32rpx;
  padding: 0;
}

.bg-shape {
  position: absolute;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(255,255,255,0.2) 0%, rgba(255,255,255,0) 100%);
  backdrop-filter: blur(4px);
}

.shape-1 {
  width: 400rpx;
  height: 400rpx;
  top: -150rpx;
  right: -100rpx;
}

.shape-2 {
  width: 240rpx;
  height: 240rpx;
  bottom: -60rpx;
  left: -80rpx;
}

.user-card {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  transition: transform 0.2s ease;
}

.user-card:active {
  transform: scale(0.98);
}

.user-id-wrap.guest-hint {
  background: rgba(255, 255, 255, 0.3);
  border-color: rgba(255, 255, 255, 0.5);
}

/* ===== 登录卡片（未登录态）===== */
.login-card {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 20rpx 32rpx 0;
}

.login-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 2rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.login-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
}

/* chooseAvatar button 去除系统默认样式后复用为头像按钮 */
.avatar-choose-btn {
  box-sizing: border-box;
  width: 192rpx;
  height: 192rpx;
  min-width: 0;           /* 覆盖 button 默认 min-width (~184rpx)，否则会被撑成椭圆 */
  max-width: 192rpx;
  padding: 0 !important;  /* 覆盖 button 默认内边距 */
  margin: 8rpx 0;
  border-radius: 50%;
  background: #FFFFFF;
  border: 8rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 16rpx 32rpx rgba(0, 0, 0, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  line-height: 1;         /* 覆盖 button 默认 line-height: 2.55555556 */
  font-size: 0;
  transition: transform 0.2s ease;
}
.avatar-choose-btn::after { border: none; }
.avatar-choose-btn:active { transform: scale(0.95); }
.avatar-choose-btn.is-loading { opacity: 0.6; }

.avatar-choose-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-choose-icon {
  font-size: 72rpx;
}

.login-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  text-align: center;
  line-height: 1.6;
  padding: 0 16rpx;
  max-width: 540rpx;
}

/* ===== 登录方式切换 Tabs ===== */
.login-mode-tabs {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-top: 8rpx;
}

.login-mode-tab {
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(8px);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  transition: all 0.2s ease;
}

.login-mode-tab.is-active {
  background: #FFFFFF;
  color: #FF6B6B;
  border-color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
}

.login-mode-tab:active {
  transform: scale(0.96);
}

/* ===== 账号密码表单 ===== */
.account-form {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  width: 560rpx;
  margin-top: 8rpx;
}

.account-input {
  box-sizing: border-box;
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: #2D3436;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.account-input-placeholder {
  color: #B2BEC3;
  font-size: 26rpx;
}

.account-submit-btn {
  box-sizing: border-box;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  margin: 8rpx 0 0;
  background: #FFFFFF;
  color: #FF6B6B;
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  border-radius: 44rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  transition: transform 0.2s ease, opacity 0.2s ease;
}

.account-submit-btn::after { border: none; }
.account-submit-btn:active { transform: scale(0.98); }
.account-submit-btn.is-loading,
.account-submit-btn[disabled] { opacity: 0.7; color: #FF6B6B !important; background: #FFFFFF !important; }

.account-toggle-link {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  text-decoration: underline;
  margin-top: 4rpx;
}

.account-toggle-link:active { opacity: 0.7; }

.account-test-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
  font-style: italic;
  margin-top: 4rpx;
  letter-spacing: 1rpx;
}

.account-error {
  width: 100%;
  font-size: 24rpx;
  color: #FFE3E3;
  background: rgba(238, 82, 83, 0.25);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 16rpx;
  padding: 12rpx 20rpx;
  text-align: center;
  font-weight: 600;
}

.user-avatar {
  margin-right: 40rpx;
  position: relative;
}

.avatar-img {
  border: 8rpx solid rgba(255, 255, 255, 0.4) !important;
  box-shadow: 0 16rpx 32rpx rgba(0, 0, 0, 0.15) !important;
}

.avatar-placeholder {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 8rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 16rpx 32rpx rgba(0, 0, 0, 0.15);
}

.avatar-placeholder text {
  font-size: 72rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.user-name {
  font-size: 48rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 2rpx;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
}

.user-id-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  align-self: flex-start;
  backdrop-filter: blur(8px);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.id-icon {
  font-size: 24rpx;
}

.user-id {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.edit-btn {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 24rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 24rpx;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(4px);
}
.edit-btn:active { opacity: 0.7; }

/* Stats Grid */
.stats-container {
  margin: -80rpx 32rpx 32rpx;
  position: relative;
  z-index: 10;
}

.stats-grid {
  background: #FFFFFF;
  border-radius: 40rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(255, 107, 107, 0.08);
  display: flex;
  padding: 40rpx 0;
  border: 2rpx solid rgba(255, 107, 107, 0.05);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.stat-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  height: 48rpx;
  width: 2rpx;
  background: #F8F9FA;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 800;
  color: #FF6B6B;
  margin-bottom: 12rpx;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
}

.stat-label {
  font-size: 24rpx;
  color: #636E72;
  font-weight: 600;
}

/* Chart Section */
.chart-section { background: #FFF; border-radius: 32rpx; padding: 32rpx; margin: 0 32rpx 32rpx; box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.04); }
.chart-header { margin-bottom: 24rpx; }
.chart-title-row { display: flex; align-items: center; gap: 12rpx; }
.chart-title { font-size: 30rpx; font-weight: 800; color: #2D3436; }
.chart-container { width: 100%; height: 360rpx; }
.stats-canvas { width: 100%; height: 100%; }

/* Chart empty state */
.chart-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  gap: 12rpx;
}
.chart-empty-emoji { font-size: 64rpx; opacity: 0.6; }
.chart-empty-text { font-size: 26rpx; font-weight: 700; color: #636E72; }
.chart-empty-hint { font-size: 22rpx; color: #B2BEC3; }

/* Menu Section */
.menu-section {
  padding: 16rpx 0;
}

.custom-cell-group {
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.04) !important;
  border-radius: 40rpx !important;
  overflow: hidden !important;
}

.menu-cell {
  padding: 40rpx 32rpx !important;
  align-items: center;
}

.menu-cell .van-cell__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
}

.menu-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  background: #FFF0E6;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.menu-icon {
  font-size: 32rpx;
}

/* Action Section */
.action-section {
  padding: 64rpx 48rpx;
}

.logout-btn {
  border: 4rpx solid #FF6B6B !important;
  color: #FF6B6B !important;
  font-weight: 800 !important;
  letter-spacing: 4rpx;
  height: 100rpx !important;
  font-size: 32rpx !important;
  border-radius: 50rpx !important;
  background: transparent !important;
}

.logout-btn:active {
  background: #FFF0E6 !important;
  transform: scale(0.98);
}

/* Animations */
.animate-fade-in {
  animation: slideUpFade 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) backwards;
}

@keyframes slideUpFade {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}