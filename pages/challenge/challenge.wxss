.challenge-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F5 0%, #FFFFFF 40%);
  padding: 40rpx 32rpx calc(env(safe-area-inset-bottom) + 40rpx);
}

/* ===== Intro Stage ===== */
.intro-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.trophy-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
  padding-top: 40rpx;
}

.trophy-icon {
  font-size: 120rpx;
  margin-bottom: 16rpx;
  filter: drop-shadow(0 8rpx 16rpx rgba(255, 215, 0, 0.3));
}

.trophy-title {
  font-size: 44rpx;
  font-weight: 900;
  color: #2D3436;
  letter-spacing: 2rpx;
}

.trophy-sub {
  font-size: 26rpx;
  color: #B2BEC3;
  margin-top: 8rpx;
  font-weight: 600;
}

.topic-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
  box-shadow: 0 12rpx 40rpx rgba(255, 107, 107, 0.1);
  border: 2rpx solid rgba(255, 107, 107, 0.08);
}

.topic-emoji {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.topic-en {
  font-size: 36rpx;
  font-weight: 800;
  color: #2D3436;
  text-align: center;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.collect-line,
.section-title-row,
.inline-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.collect-line {
  width: 100%;
  justify-content: center;
  margin-bottom: 16rpx;
}

.collect-line .topic-en {
  flex: 1;
  margin-bottom: 0;
}

.section-title-row {
  justify-content: space-between;
}

.inline-actions {
  flex-shrink: 0;
}

.collect-icon-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #F8F9FA;
  color: #FF9F43;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.collect-icon-btn:active {
  transform: scale(0.9);
}

.topic-zh {
  font-size: 28rpx;
  color: #636E72;
  text-align: center;
  margin-bottom: 24rpx;
}

.topic-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.topic-day {
  font-size: 24rpx;
  color: #FF6B6B;
  font-weight: 700;
}

.intro-actions {
  width: 100%;
}

.leaderboard-link {
  text-align: center;
  margin-top: 32rpx;
  padding: 16rpx;
}

.leaderboard-link text {
  font-size: 28rpx;
  color: #FF6B6B;
  font-weight: 700;
}

/* ===== Recording Stage ===== */
.recording-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.timer-circle {
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  margin-bottom: 60rpx;
  box-shadow: 0 16rpx 48rpx rgba(255, 107, 107, 0.35);
}

.timer-pulse {
  position: absolute;
  top: -16rpx;
  left: -16rpx;
  right: -16rpx;
  bottom: -16rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 107, 107, 0.4);
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.08); opacity: 0.2; }
}

.timer-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.timer-number {
  font-size: 88rpx;
  font-weight: 900;
  color: #FFFFFF;
  line-height: 1;
}

.timer-unit {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 600;
  margin-top: 8rpx;
}

.recording-topic {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D3436;
  text-align: center;
  margin-bottom: 16rpx;
  padding: 0 20rpx;
}

.recording-hint {
  font-size: 26rpx;
  color: #B2BEC3;
  margin-bottom: 60rpx;
}

/* ===== Evaluating Stage ===== */
.evaluating-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 32rpx;
}

.evaluating-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D3436;
}

.evaluating-sub {
  font-size: 26rpx;
  color: #B2BEC3;
}

/* ===== Result Stage ===== */
.result-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-score-circle {
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B6B, #FF9F43);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
  box-shadow: 0 16rpx 48rpx rgba(255, 107, 107, 0.3);
  position: relative;
}

.result-score-emoji {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.result-score-num {
  font-size: 80rpx;
  font-weight: 900;
  color: #FFFFFF;
  line-height: 1;
}

.result-score-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 600;
  margin-top: 8rpx;
}

.result-dimensions {
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.04);
}

.dim-item {
  margin-bottom: 24rpx;
}

.dim-item:last-child {
  margin-bottom: 0;
}

.dim-label {
  font-size: 26rpx;
  color: #636E72;
  font-weight: 600;
  margin-bottom: 12rpx;
  display: block;
}

.result-spoken {
  width: 100%;
  background: #F8F9FA;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.spoken-label {
  font-size: 24rpx;
  color: #B2BEC3;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.spoken-text {
  font-size: 28rpx;
  color: #2D3436;
  line-height: 1.6;
  display: block;
}

.result-feedback {
  width: 100%;
  background: rgba(255, 107, 107, 0.06);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.feedback-text {
  flex: 1;
  font-size: 28rpx;
  color: #2D3436;
  line-height: 1.6;
}

.result-encouragement {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 40rpx;
}

.encouragement-text {
  font-size: 30rpx;
  color: #FF6B6B;
  font-weight: 700;
}

.play-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  border-radius: 50%;
  font-size: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
  margin-left: 16rpx;
}

.play-btn.playing {
  background: #FF6B6B;
  color: #FFFFFF;
  animation: playPulse 1s infinite;
}

@keyframes playPulse {
  0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(255, 107, 107, 0.4); }
  70% { transform: scale(1.1); box-shadow: 0 0 0 10rpx rgba(255, 107, 107, 0); }
  100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(255, 107, 107, 0); }
}

/* ===== Confetti Animation ===== */
.confetti-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 100;
}

.confetti-piece {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  background: #FF6B6B;
  top: -20rpx;
  opacity: 0;
  animation: confettiFall 3s ease-out forwards;
}

.confetti-piece:nth-child(2n) { background: #FECA57; }
.confetti-piece:nth-child(3n) { background: #10AC84; }
.confetti-piece:nth-child(4n) { background: #54A0FF; }
.confetti-piece:nth-child(5n) { background: #FF9F43; }

.confetti-piece:nth-child(1) { left: 10%; animation-delay: 0s; }
.confetti-piece:nth-child(2) { left: 20%; animation-delay: 0.2s; }
.confetti-piece:nth-child(3) { left: 30%; animation-delay: 0.1s; }
.confetti-piece:nth-child(4) { left: 40%; animation-delay: 0.4s; }
.confetti-piece:nth-child(5) { left: 50%; animation-delay: 0.3s; }
.confetti-piece:nth-child(6) { left: 60%; animation-delay: 0.6s; }
.confetti-piece:nth-child(7) { left: 70%; animation-delay: 0.5s; }
.confetti-piece:nth-child(8) { left: 80%; animation-delay: 0.8s; }
.confetti-piece:nth-child(9) { left: 90%; animation-delay: 0.7s; }
.confetti-piece:nth-child(10) { left: 15%; animation-delay: 1s; }
.confetti-piece:nth-child(11) { left: 25%; animation-delay: 1.2s; }
.confetti-piece:nth-child(12) { left: 35%; animation-delay: 1.1s; }
.confetti-piece:nth-child(13) { left: 45%; animation-delay: 1.4s; }
.confetti-piece:nth-child(14) { left: 55%; animation-delay: 1.3s; }
.confetti-piece:nth-child(15) { left: 65%; animation-delay: 1.6s; }
.confetti-piece:nth-child(16) { left: 75%; animation-delay: 1.5s; }
.confetti-piece:nth-child(17) { left: 85%; animation-delay: 1.8s; }
.confetti-piece:nth-child(18) { left: 95%; animation-delay: 1.7s; }
.confetti-piece:nth-child(19) { left: 5%; animation-delay: 1.9s; }
.confetti-piece:nth-child(20) { left: 50%; animation-delay: 2s; }

@keyframes confettiFall {
  0% { transform: translateY(0) rotate(0deg); opacity: 1; }
  100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
}

.result-actions {
  width: 100%;
  margin-top: 16rpx;
}

/* ===== Leaderboard Stage ===== */
.leaderboard-container {
  padding-top: 20rpx;
}

.lb-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.lb-title {
  font-size: 40rpx;
  font-weight: 900;
  color: #2D3436;
}

.lb-sub {
  font-size: 24rpx;
  color: #B2BEC3;
  margin-top: 8rpx;
  font-weight: 600;
}

.lb-list {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.04);
}

.lb-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid #F5F6FA;
}

.lb-item:last-child {
  border-bottom: none;
}

.lb-item-me {
  background: rgba(255, 107, 107, 0.06);
}

.lb-top {
  background: linear-gradient(90deg, rgba(255, 215, 0, 0.06) 0%, transparent 100%);
}

.lb-rank {
  width: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.lb-medal {
  font-size: 40rpx;
}

.lb-rank-num {
  font-size: 30rpx;
  font-weight: 800;
  color: #B2BEC3;
}

.lb-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  color: #2D3436;
  margin-left: 16rpx;
}

.lb-score {
  font-size: 32rpx;
  font-weight: 900;
  color: #FF6B6B;
}

.lb-empty {
  padding: 80rpx 32rpx;
  text-align: center;
}

.lb-empty text {
  font-size: 28rpx;
  color: #B2BEC3;
}

/* ===== Shared ===== */
.shadow-card {
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}
