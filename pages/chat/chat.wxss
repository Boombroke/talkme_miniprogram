/* Chat Page - Modern Warm Aesthetic */

.chat-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F8F9FA; /* Warm off-white */
}

.message-list {
  flex: 1;
  padding: 32rpx 0;
  overflow-y: auto;
}

.scene-banner-wrapper {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0% { transform: translateY(0); }
  50% { transform: translateY(-4rpx); }
  100% { transform: translateY(0); }
}

.scene-banner {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 32rpx;
  background: rgba(255, 107, 107, 0.1); /* Soft coral bg */
  border-radius: 40rpx;
  border: 2rpx solid rgba(255, 107, 107, 0.2);
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.05);
}

.scene-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.scene-banner-text {
  font-size: 26rpx;
  color: #FF6B6B;
  font-weight: bold;
  letter-spacing: 2rpx;
}

/* Scene progress indicator */
.scene-progress { padding: 0 48rpx 16rpx; display: flex; align-items: center; gap: 16rpx; }
.progress-bar { flex: 1; height: 8rpx; background: rgba(255,107,107,0.15); border-radius: 4rpx; overflow: hidden; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #FF6B6B, #FF9F43); border-radius: 4rpx; transition: width 0.5s ease; }
.progress-text { font-size: 22rpx; color: #B2BEC3; font-weight: 600; white-space: nowrap; }

.message-container {
  padding-bottom: 32rpx;
}

.message-item {
  margin-bottom: 16rpx;
}

/* Loading animation - Bouncing Dots */
.loading-indicator {
  padding: 16rpx 32rpx;
  display: flex;
  align-items: center;
}

.loading-bubble {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  padding: 24rpx 32rpx;
  border-radius: 32rpx 32rpx 32rpx 8rpx;
  margin-left: 104rpx; /* Align with AI bubble */
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.bouncing-dots {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.bouncing-dots .dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #FF6B6B;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}

.bouncing-dots .dot:nth-child(1) { animation-delay: -0.32s; }
.bouncing-dots .dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

/* Input Area */
.input-area {
  background: transparent;
  padding: 0 24rpx 24rpx; /* Lifted off bottom */
}

.input-container {
  background: #FFFFFF;
  border-radius: 48rpx;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.end-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  background: #FFF0E6; /* Muted pink/warm bg */
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.end-btn:active {
  transform: scale(0.9);
  background: #FFE4D6;
}

.end-icon {
  font-size: 32rpx;
}

.switch-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
  background: #F8F9FA;
  border-radius: 50%;
  transition: all 0.3s ease;
}

.switch-btn.is-voice {
  background: rgba(255, 107, 107, 0.1);
}

.switch-btn:active {
  transform: scale(0.9);
}

.switch-icon {
  font-size: 36rpx;
}

.text-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #F8F9FA;
  border-radius: 36rpx;
  padding: 8rpx 12rpx 8rpx 32rpx;
  transition: all 0.3s ease;
}

.text-input-wrap:focus-within {
  background: #FFFFFF;
  box-shadow: inset 0 0 0 2rpx rgba(255, 107, 107, 0.2);
}

.modern-text-input {
  font-size: 30rpx !important;
  color: #2D3436 !important;
  height: 64rpx !important;
  line-height: 64rpx !important;
  width: 100% !important;
  font-weight: 500 !important;
}

.send-btn-wrap {
  margin-left: 16rpx;
  flex-shrink: 0;
}

.modern-send-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  padding: 0 32rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF9F43);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 16rpx rgba(255, 107, 107, 0.3);
  transition: all 0.2s ease;
}

.modern-send-btn:active:not(.disabled) {
  transform: scale(0.95);
  box-shadow: 0 4rpx 8rpx rgba(255, 107, 107, 0.2);
}

.modern-send-btn.disabled {
  background: #E2E8F0;
  box-shadow: none;
  color: #A0AEC0;
}

.voice-input-wrap {
  flex: 1;
}

/* Safe area */
.safe-bottom {
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
