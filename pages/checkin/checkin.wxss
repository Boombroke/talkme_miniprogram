.checkin-page {
  min-height: 100vh;
  background: #F8F9FA;
  padding: 32rpx 24rpx calc(110rpx + env(safe-area-inset-bottom) + 48rpx);
  box-sizing: border-box;
}

/* Animations */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-fade-in-up > view {
  animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  opacity: 0;
}

.stagger-1 { animation-delay: 0.1s; }
.stagger-2 { animation-delay: 0.2s; }
.stagger-3 { animation-delay: 0.3s; }
.stagger-4 { animation-delay: 0.4s; }
.stagger-5 { animation-delay: 0.5s; }

/* Colors */
.text-coral { color: #FF6B6B; }
.text-orange { color: #FF9F43; }
.text-teal { color: #10AC84; }

/* Section 1: Streak Banner + Check-in */
.streak-row {
  background: linear-gradient(135deg, #FF6B6B, #FF9F43);
  border-radius: 40rpx;
  padding: 40rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 16rpx 48rpx rgba(255, 107, 107, 0.3);
  margin-bottom: 32rpx;
  height: 240rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.streak-row::after {
  content: '';
  position: absolute;
  top: -30%;
  right: -10%;
  width: 240rpx;
  height: 240rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.2) 0%, rgba(255, 255, 255, 0) 70%);
  border-radius: 50%;
  z-index: 1;
}

.streak-info {
  display: flex;
  align-items: center;
  z-index: 2;
}

.streak-fire {
  line-height: 1;
  margin-right: 12rpx;
  animation: float 3s ease-in-out infinite;
}
.total-fire {
  line-height: 1;
  margin-right: 12rpx;
  animation: float 2.5s ease-in-out infinite;
  animation-delay: 0.3s;
}
.streak-divider-dot {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.3);
  margin-right: 12rpx;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.streak-nums {
  display: flex;
  flex-direction: column;
  margin-right: 24rpx;
}

.streak-big {
  font-size: 64rpx;
  font-weight: 900;
  color: #FFFFFF;
  line-height: 1;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}

.streak-unit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 700;
  margin-top: 8rpx;
}

.streak-total {
  display: flex;
  flex-direction: column;
  padding-left: 32rpx;
  border-left: 2rpx solid rgba(255, 255, 255, 0.3);
}

.total-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1;
}

.total-unit {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
  margin-top: 8rpx;
}

.checkin-btn-compact {
  width: 140rpx;
  height: 140rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  font-weight: 800;
  color: #FFFFFF;
  z-index: 2;
  transition: all 0.3s ease;
  backdrop-filter: blur(10px);
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.checkin-btn-compact:active {
  transform: scale(0.95);
}

.checkin-btn-compact.checked {
  background: #FFFFFF;
  color: #FF6B6B;
  border-color: #FFFFFF;
}

.checkin-btn-compact.loading {
  opacity: 0.7;
  pointer-events: none;
}

/* Section 2: Today's Stats Card */
.today-section {
  margin-bottom: 32rpx;
}

.summary-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-value {
  font-size: 44rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.summary-label {
  font-size: 22rpx;
  color: #B2BEC3;
  font-weight: 600;
  text-transform: uppercase;
}

.summary-divider {
  width: 2rpx;
  height: 60rpx;
  background: #F8F9FA;
}

/* Section 3: Learning Data Dashboard */
.insights-section {
  margin-bottom: 32rpx;
}

.insights-header {
  margin-bottom: 24rpx;
  padding-left: 16rpx;
}

.insights-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #2D3436;
}

/* Mode filter horizontal tabs */
.mode-filter {
  margin-bottom: 24rpx;
  width: 100%;
}
.mode-filter-inner {
  display: flex;
  gap: 16rpx;
  padding: 0 4rpx 8rpx;
}
.mode-tab {
  flex-shrink: 0;
  padding: 10rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #636E72;
  background: #FFFFFF;
  border: 2rpx solid rgba(0,0,0,0.04);
  white-space: nowrap;
}
.mode-tab.active {
  background: #FF6B6B;
  color: #FFFFFF;
  border-color: #FF6B6B;
}

.insights-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

/* Single mode detail view */
.mode-detail-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.04);
}
.mode-detail-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.mode-detail-emoji {
  font-size: 64rpx;
}
.mode-detail-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.mode-detail-name {
  font-size: 32rpx;
  font-weight: 800;
  color: #2D3436;
}
.mode-detail-count {
  font-size: 26rpx;
  color: #636E72;
  font-weight: 600;
}
.mode-detail-num {
  font-size: 36rpx;
  font-weight: 900;
  color: #FF6B6B;
}

.insight-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
}

.insight-value {
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.insight-label {
  font-size: 22rpx;
  color: #636E72;
  font-weight: 500;
}

/* Section 4: Leaderboard */
.leaderboard-section {
  margin-bottom: 32rpx;
}

.leaderboard-header {
  margin-bottom: 24rpx;
  padding-left: 16rpx;
}

.leaderboard-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #2D3436;
}

.leaderboard-list {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 16rpx 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.leader-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #F8F9FA;
}

.leader-item:last-child {
  border-bottom: none;
}

.leader-item.is-me {
  background: rgba(255, 107, 107, 0.05);
  border-radius: 16rpx;
  margin: 0 -16rpx;
  padding: 24rpx 16rpx;
  border-left: 8rpx solid #FF6B6B;
}

.leader-rank {
  width: 60rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #B2BEC3;
  text-align: center;
}

.leader-rank.top-1, .leader-rank.top-2, .leader-rank.top-3 {
  font-size: 36rpx;
}

.leader-name {
  flex: 1;
  font-size: 28rpx;
  color: #2D3436;
  font-weight: 600;
  margin: 0 24rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.leader-score {
  font-size: 28rpx;
  font-weight: 800;
  color: #FF6B6B;
}

.leaderboard-empty {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 64rpx 0;
  text-align: center;
  color: #B2BEC3;
  font-size: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

/* Section 5: Calendar */
.calendar-section {
  margin-bottom: 32rpx;
}

.calendar-header {
  margin-bottom: 24rpx;
  padding-left: 16rpx;
}

.calendar-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #2D3436;
}

.calendar-wrapper {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

/* Section 6: Share */
.share-row {
  display: flex;
  justify-content: center;
  margin-top: 48rpx;
}

.share-btn {
  display: inline-flex;
  align-items: center;
  padding: 20rpx 64rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF9F43);
  color: #FFF;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
  transition: all 0.2s ease;
}

.share-btn:active {
  transform: scale(0.95);
}

.poster-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 600px;
  height: 900px;
}
