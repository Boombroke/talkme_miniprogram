.scene-page {
  min-height: 100vh;
  background: #F8F9FA;
  padding: 24rpx;
  box-sizing: border-box;
}

/* Animations */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUpFade {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-fade-in {
  animation: fadeIn 0.6s ease-out forwards;
}

.animate-stagger {
  opacity: 0;
  animation: slideUpFade 0.5s ease-out forwards;
}

.page-header {
  padding: 16rpx 8rpx 40rpx;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #FF6B6B, #FF9F43);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.header-desc {
  font-size: 28rpx;
  color: #636E72;
  font-weight: 500;
}

.scene-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.scene-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 36rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.08);
  transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.2s ease;
}

.scene-card:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.04);
}

.scene-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  flex-shrink: 0;
  background: #FFF0E6;
}

.scene-icon {
  font-size: 64rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.1));
}

.scene-info {
  flex: 1;
  min-width: 0;
}

.scene-name-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.scene-name {
  font-size: 34rpx;
  font-weight: 800;
  color: #2D3436;
  margin-right: 16rpx;
}

.scene-name-en {
  font-size: 24rpx;
  color: #B2BEC3;
  font-weight: 600;
}

.scene-desc {
  font-size: 26rpx;
  color: #636E72;
  margin-bottom: 16rpx;
  display: block;
  line-height: 1.5;
}

.scene-meta {
  display: flex;
  align-items: center;
}

.difficulty-tag {
  margin-right: 16rpx;
  padding: 6rpx 16rpx !important;
  font-weight: 600;
  font-size: 22rpx !important;
}

.ai-role {
  font-size: 22rpx;
  color: #FF9F43;
  background: #FFF0E6;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

.scene-arrow {
  margin-left: 16rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #FFF0E6;
}