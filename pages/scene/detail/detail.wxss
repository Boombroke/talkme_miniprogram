.detail-page {
  min-height: 100vh;
  background: #F8F9FA;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
}

/* Animations */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUpFade {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes popIn {
  0% {
    opacity: 0;
    transform: scale(0.8);
  }
  70% {
    transform: scale(1.1);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

.animate-fade-in {
  animation: fadeIn 0.4s ease-out forwards;
}

.animate-pop {
  animation: popIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}

.stagger-1, .stagger-2, .stagger-3, .stagger-4, .stagger-5, .stagger-6, .stagger-7 {
  opacity: 0;
  animation: slideUpFade 0.5s ease-out forwards;
}

.stagger-1 { animation-delay: 0.1s; }
.stagger-2 { animation-delay: 0.15s; }
.stagger-3 { animation-delay: 0.2s; }
.stagger-4 { animation-delay: 0.3s; }
.stagger-5 { animation-delay: 0.4s; }
.stagger-6 { animation-delay: 0.5s; }
.stagger-7 { animation-delay: 0.6s; }

.scene-header {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF9F43 100%);
  padding: 64rpx 32rpx 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(255, 107, 107, 0.3);
  border-bottom-left-radius: 64rpx;
  border-bottom-right-radius: 64rpx;
  margin-bottom: 40rpx;
}

.header-icon-bg {
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  transform: rotate(-15deg);
  pointer-events: none;
  opacity: 0.15;
}

.bg-icon-text {
  font-size: 400rpx;
  line-height: 1;
}

.scene-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
  filter: drop-shadow(0 8rpx 16rpx rgba(0, 0, 0, 0.15));
  background: rgba(255, 255, 255, 0.2);
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 48rpx;
  backdrop-filter: blur(10px);
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.scene-name {
  font-size: 44rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
  position: relative;
  z-index: 1;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.scene-name-en {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 24rpx;
  font-weight: 600;
  position: relative;
  z-index: 1;
}

.scene-tags {
  display: flex;
  gap: 16rpx;
  position: relative;
  z-index: 1;
}

.header-tag {
  padding: 8rpx 24rpx !important;
  font-size: 24rpx !important;
  font-weight: 600 !important;
  backdrop-filter: blur(8px);
  border: 2rpx solid rgba(255, 255, 255, 0.3) !important;
}

.content-wrapper {
  padding-bottom: 200rpx;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #2D3436;
  margin-bottom: 24rpx;
  padding-left: 36rpx;
}

.card-group {
  border-radius: 32rpx !important;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.04) !important;
}

.desc-text {
  font-size: 28rpx;
  color: #636E72;
  line-height: 1.8;
  text-align: justify;
  font-weight: 500;
}

.phrase-item {
  display: flex;
  align-items: flex-start;
  padding: 8rpx 0;
}

.phrase-bullet {
  margin-right: 16rpx;
  font-size: 28rpx;
  margin-top: 4rpx;
}

.phrase-text {
  font-size: 28rpx;
  color: #2D3436;
  line-height: 1.6;
  flex: 1;
  font-weight: 500;
}

.vocab-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 8rpx 0;
}

.vocab-tag {
  font-size: 26rpx !important;
  padding: 10rpx 28rpx !important;
  font-weight: 600 !important;
  border: none !important;
}

.start-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx 48rpx;
  padding-bottom: calc(32rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(248, 249, 250, 0) 0%, #F8F9FA 20%);
  z-index: 100;
}

.start-btn-custom {
  background: linear-gradient(135deg, #FF6B6B, #FF9F43) !important;
  color: white !important;
  height: 100rpx !important;
  line-height: 100rpx !important;
  border-radius: 50rpx !important;
  font-size: 34rpx !important;
  font-weight: 800 !important;
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 107, 0.4) !important;
  letter-spacing: 4rpx !important;
  border: none !important;
}

.start-btn-custom::after {
  border: none;
}

.start-btn-custom:active {
  transform: scale(0.96);
  box-shadow: 0 6rpx 16rpx rgba(255, 107, 107, 0.3) !important;
}