/* Grammar Drill Page — Coral Design System */

.grammar-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF0E6 0%, #F8F9FA 30%);
  padding: 32rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

/* ========== LOADING / CHECKING ========== */
.stage-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.loading-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D3436;
}

.loading-sub {
  font-size: 24rpx;
  color: #B2BEC3;
}

/* ========== QUESTION STAGE ========== */
.progress-bar-wrap {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.progress-track {
  flex: 1;
  height: 12rpx;
  background: rgba(255, 107, 107, 0.15);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B6B, #FF9F43);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.progress-label {
  font-size: 26rpx;
  color: #636E72;
  font-weight: 700;
  white-space: nowrap;
}

.question-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.question-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  justify-content: space-between;
}

.question-tags {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
  flex: 1;
}

.type-tag {
  font-weight: 600 !important;
}

.hint-tag {
  font-weight: 600 !important;
}

.question-instruction {
  font-size: 28rpx;
  font-weight: 600;
  color: #636E72;
  display: block;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.question-sentence-wrap {
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.06), rgba(255, 159, 67, 0.06));
  border-radius: 24rpx;
  padding: 28rpx;
  border-left: 6rpx solid #FF6B6B;
}

.question-sentence {
  font-size: 34rpx;
  font-weight: 700;
  color: #2D3436;
  line-height: 1.7;
}

.collect-line,
.compare-value-row,
.answer-val-row,
.card-title-row,
.summary-item-actions {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.collect-line .question-sentence,
.compare-value-row .compare-value,
.answer-val-row .answer-val {
  flex: 1;
}

.card-title-row,
.summary-item-actions {
  align-items: center;
  justify-content: space-between;
}

.collect-icon-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #F8F9FA;
  color: #FF9F43;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.collect-icon-btn:active {
  transform: scale(0.9);
}

/* 填空题：句子内嵌多个输入框 */
.sentence-inline {
  display: block;
  line-height: 2.2;
}
.sentence-inline .question-sentence {
  display: inline;
}
/* 宽度用 CSS 变量 --ch（字符数）动态撑；JS 里通过 style="--ch: N" 注入 */
.blank-input {
  display: inline-block;
  width: calc(var(--ch, 4) * 1ch + 32rpx);  /* 1ch ≈ 一个数字/字母宽度；32rpx 为左右 padding */
  min-width: 80rpx;
  max-width: 90%;
  padding: 0 16rpx;
  margin: 0 6rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #FF6B6B;
  background: transparent;               /* 与页面背景同色，不再出现白色方块 */
  border-bottom: 3rpx solid #FF6B6B;
  border-radius: 0;                       /* 只保留下划线 */
  text-align: center;
  vertical-align: middle;
  box-sizing: content-box;
  transition: width 0.15s ease;
}
.blank-placeholder {
  color: rgba(255, 107, 107, 0.35);
  font-weight: 500;
}

/* ========== ANSWER INPUT ========== */
.answer-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.answer-input-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  border: 2rpx solid #DFE6E9;
  transition: border-color 0.3s ease;
}

.answer-input-card:focus-within {
  border-color: #FF6B6B;
}

.answer-input {
  font-size: 30rpx !important;
  color: #2D3436 !important;
  font-weight: 500 !important;
  min-height: 80rpx !important;
}

/* ========== RESULT STAGE ========== */
.result-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
}

.result-banner.correct {
  background: linear-gradient(135deg, rgba(16, 172, 132, 0.1), rgba(16, 172, 132, 0.05));
  border: 2rpx solid rgba(16, 172, 132, 0.2);
}

.result-banner.wrong {
  background: linear-gradient(135deg, rgba(238, 82, 83, 0.1), rgba(238, 82, 83, 0.05));
  border: 2rpx solid rgba(238, 82, 83, 0.2);
}

.result-banner-icon {
  font-size: 56rpx;
}

.result-banner-text {
  font-size: 40rpx;
  font-weight: 900;
}

.result-banner.correct .result-banner-text { color: #10AC84; }
.result-banner.wrong .result-banner-text { color: #EE5253; }

.answer-compare-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.compare-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.compare-label {
  font-size: 24rpx;
  color: #B2BEC3;
  font-weight: 600;
  width: 100rpx;
  flex-shrink: 0;
  padding-top: 4rpx;
}

.compare-value {
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.5;
  flex: 1;
  word-break: break-word;
}

.text-correct { color: #10AC84; }
.text-wrong { color: #EE5253; }
.correct-answer { color: #10AC84; }

.compare-divider {
  height: 2rpx;
  background: #F0F0F0;
  margin: 20rpx 0;
}

.explanation-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.explanation-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2D3436;
  display: block;
  margin-bottom: 16rpx;
}

.explanation-text {
  font-size: 26rpx;
  color: #636E72;
  line-height: 1.7;
  display: block;
}

.feedback-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.feedback-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2D3436;
  display: block;
  margin-bottom: 16rpx;
}

.feedback-text {
  font-size: 26rpx;
  color: #636E72;
  line-height: 1.7;
  display: block;
}

.result-actions {
  margin-top: 32rpx;
}

/* ========== SUMMARY STAGE ========== */
.summary-score-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.summary-emoji {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.summary-score-wrap {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.summary-score {
  font-size: 96rpx;
  font-weight: 900;
  line-height: 1;
}

.summary-score-total {
  font-size: 36rpx;
  font-weight: 600;
  color: #B2BEC3;
}

.summary-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #636E72;
}

.summary-results {
  margin-bottom: 32rpx;
}

.summary-section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #2D3436;
  display: block;
  margin-bottom: 20rpx;
}

.summary-item {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.summary-item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.summary-item-num {
  font-size: 28rpx;
  font-weight: 800;
  color: #FF6B6B;
}

.summary-item-icon {
  font-size: 36rpx;
}

.summary-item-sentence {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3436;
  line-height: 1.6;
  display: block;
  margin-bottom: 16rpx;
}

.summary-item-answers {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.summary-answer-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.answer-label {
  font-size: 24rpx;
  color: #B2BEC3;
  font-weight: 600;
  flex-shrink: 0;
}

.answer-val {
  font-size: 26rpx;
  font-weight: 700;
}

.summary-item-explanation {
  font-size: 24rpx;
  color: #636E72;
  line-height: 1.6;
  display: block;
  padding-top: 12rpx;
  border-top: 2rpx solid #F0F0F0;
}

.summary-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ========== SHARED BUTTON STYLES ========== */
.btn-submit {
  background: linear-gradient(135deg, #FF6B6B, #FF9F43) !important;
  border: none !important;
  font-weight: 700 !important;
  font-size: 32rpx !important;
  height: 96rpx !important;
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 107, 0.3);
}

.btn-next {
  background: linear-gradient(135deg, #FF6B6B, #FF9F43) !important;
  border: none !important;
  font-weight: 700 !important;
  font-size: 32rpx !important;
  height: 96rpx !important;
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 107, 0.3);
}

.btn-retry {
  background: linear-gradient(135deg, #FF6B6B, #FF9F43) !important;
  border: none !important;
  font-weight: 700 !important;
  font-size: 32rpx !important;
  height: 96rpx !important;
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 107, 0.3);
}

.btn-home {
  border-color: #DFE6E9 !important;
  color: #636E72 !important;
  font-weight: 600 !important;
  font-size: 30rpx !important;
  height: 88rpx !important;
}

.btn-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.btn-icon {
  font-size: 36rpx;
}
