.shadow-page {
  min-height: 100vh;
  background: #F8F9FA;
  padding: 32rpx 24rpx 64rpx;
  box-sizing: border-box;
}

/* ========== Round Indicator ========== */
.round-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.round-dots {
  display: flex;
  gap: 12rpx;
}

.round-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #DFE6E9;
  transition: all 0.3s ease;
}

.round-dot.active {
  width: 40rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF9F43);
}

.round-dot.done {
  background: #10AC84;
}

.round-text {
  font-size: 24rpx;
  color: #B2BEC3;
  font-weight: 700;
}

/* ========== Sentence Card ========== */
.sentence-card {
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 64rpx 40rpx;
  margin-bottom: 48rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.04);
  position: relative;
  min-height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quote-mark {
  position: absolute;
  font-size: 120rpx;
  color: rgba(255, 107, 107, 0.12);
  font-family: Georgia, serif;
  font-weight: 900;
  line-height: 1;
}

.quote-mark.left {
  top: 16rpx;
  left: 24rpx;
}

.quote-mark.right {
  bottom: -16rpx;
  right: 24rpx;
}

.sentence-overlay {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.overlay-icon {
  font-size: 80rpx;
  animation: pulse 2s infinite;
}

.overlay-hint {
  font-size: 30rpx;
  color: #B2BEC3;
  font-weight: 600;
}

.sentence-text {
  font-size: 36rpx;
  color: #2D3436;
  font-weight: 700;
  line-height: 1.8;
  text-align: center;
  letter-spacing: 1rpx;
}

.sentence-card.revealed {
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF8F0 100%);
  border: 2rpx solid rgba(255, 107, 107, 0.1);
}

/* ========== Speaker Animation ========== */
.speaker-anim {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin: 32rpx auto;
}

.pulse-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 107, 107, 0.3);
  animation: pulseRing 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

.ring2 { animation-delay: 0.4s; }
.ring3 { animation-delay: 0.8s; }

@keyframes pulseRing {
  0% { transform: scale(0.6); opacity: 1; }
  100% { transform: scale(1.6); opacity: 0; }
}

.speaker-icon {
  font-size: 64rpx;
  z-index: 1;
}

.stage-hint {
  text-align: center;
  font-size: 26rpx;
  color: #B2BEC3;
  font-weight: 600;
}

/* ========== Recording Section ========== */
.recording-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.recording-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #FF6B6B;
  letter-spacing: 2rpx;
}

.mic-anim {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mic-pulse {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: rgba(255, 107, 107, 0.15);
  animation: micPulse 1.5s ease-in-out infinite;
}

.mic-pulse.p2 {
  animation-delay: 0.5s;
}

@keyframes micPulse {
  0%, 100% { transform: scale(0.8); opacity: 0.6; }
  50% { transform: scale(1.4); opacity: 0; }
}

.mic-icon {
  font-size: 64rpx;
  z-index: 1;
}

.record-timer {
  font-size: 48rpx;
  font-weight: 900;
  color: #2D3436;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
}

/* ========== Comparing Stage ========== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
  gap: 24rpx;
}

.loading-text {
  font-size: 26rpx;
  color: #B2BEC3;
}

/* ========== Result Stage ========== */
.stage-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

/* Confetti */
.confetti-container {
  position: absolute;
  top: -40rpx;
  left: 0;
  width: 100%;
  height: 200rpx;
  pointer-events: none;
  z-index: 10;
  display: flex;
  justify-content: center;
}

.confetti-piece {
  position: absolute;
  width: 16rpx;
  height: 24rpx;
  background: #FF6B6B;
  opacity: 0;
  animation: confettiFall 2s ease-out forwards;
}

.confetti-piece:nth-child(even) { background: #FF9F43; border-radius: 50%; }
.confetti-piece:nth-child(3n) { background: #1DD1A1; }
.confetti-piece:nth-child(4n) { background: #54A0FF; }

/* Randomize confetti positions/delays slightly */
.confetti-piece:nth-child(1) { left: 10%; animation-delay: 0.1s; }
.confetti-piece:nth-child(2) { left: 20%; animation-delay: 0.3s; }
.confetti-piece:nth-child(3) { left: 30%; animation-delay: 0.2s; }
.confetti-piece:nth-child(4) { left: 40%; animation-delay: 0.4s; }
.confetti-piece:nth-child(5) { left: 50%; animation-delay: 0.1s; }
.confetti-piece:nth-child(6) { left: 60%; animation-delay: 0.5s; }
.confetti-piece:nth-child(7) { left: 70%; animation-delay: 0.2s; }
.confetti-piece:nth-child(8) { left: 80%; animation-delay: 0.4s; }
.confetti-piece:nth-child(9) { left: 90%; animation-delay: 0.1s; }
.confetti-piece:nth-child(10) { left: 15%; animation-delay: 0.6s; }
.confetti-piece:nth-child(11) { left: 25%; animation-delay: 0.2s; }
.confetti-piece:nth-child(12) { left: 35%; animation-delay: 0.5s; }
.confetti-piece:nth-child(13) { left: 45%; animation-delay: 0.3s; }
.confetti-piece:nth-child(14) { left: 55%; animation-delay: 0.7s; }
.confetti-piece:nth-child(15) { left: 65%; animation-delay: 0.1s; }
.confetti-piece:nth-child(16) { left: 75%; animation-delay: 0.4s; }
.confetti-piece:nth-child(17) { left: 85%; animation-delay: 0.2s; }
.confetti-piece:nth-child(18) { left: 95%; animation-delay: 0.6s; }
.confetti-piece:nth-child(19) { left: 5%; animation-delay: 0.3s; }
.confetti-piece:nth-child(20) { left: 50%; animation-delay: 0.5s; }

@keyframes confettiFall {
  0% { transform: translateY(-50rpx) rotate(0deg); opacity: 1; }
  100% { transform: translateY(300rpx) rotate(360deg); opacity: 0; }
}

.encouragement-box {
  background: rgba(255, 159, 67, 0.1);
  border: 2rpx dashed rgba(255, 159, 67, 0.5);
  border-radius: 20rpx;
  padding: 16rpx 32rpx;
  margin-bottom: 32rpx;
  text-align: center;
}

.encouragement-text {
  color: #FF9F43;
  font-size: 28rpx;
  font-weight: 700;
}

.score-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.08);
}

.score-circle.score-green {
  background: linear-gradient(135deg, #10AC84, #1DD1A1);
}

.score-circle.score-orange {
  background: linear-gradient(135deg, #FF9F43, #FECA57);
}

.score-circle.score-red {
  background: linear-gradient(135deg, #FF6B6B, #EE5253);
}

.score-number {
  font-size: 72rpx;
  font-weight: 900;
  color: #FFFFFF;
  line-height: 1;
}

.score-percent {
  font-size: 32rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.score-label {
  font-size: 28rpx;
  color: #B2BEC3;
  font-weight: 700;
  margin-bottom: 32rpx;
  letter-spacing: 2rpx;
}

.progress-bar {
  width: 100%;
  margin-bottom: 40rpx;
}

/* ========== Comparison Section ========== */
.compare-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 48rpx;
}

.compare-item {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.04);
}

.compare-label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.compare-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: #B2BEC3;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.play-btn-small {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F8F9FA;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  transition: all 0.2s;
}

.play-btn-small:active {
  transform: scale(0.9);
}

.play-btn-small.playing {
  background: rgba(255, 107, 107, 0.1);
  border: 2rpx solid #FF6B6B;
  animation: pulse-small 1.5s infinite;
}

@keyframes pulse-small {
  0% { box-shadow: 0 0 0 0 rgba(255, 107, 107, 0.4); }
  70% { box-shadow: 0 0 0 16rpx rgba(255, 107, 107, 0); }
  100% { box-shadow: 0 0 0 0 rgba(255, 107, 107, 0); }
}

.compare-icon {
  font-size: 28rpx;
}

.compare-text {
  font-size: 30rpx;
  line-height: 1.7;
  font-weight: 600;
  display: block;
}

.compare-text.original {
  color: #2D3436;
}

.compare-text.spoken {
  color: #636E72;
}

.feedback-text {
  color: #FF9F43;
  font-style: italic;
}

/* ========== Summary Stage ========== */
.summary-banner {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF9F43);
  border-radius: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 16rpx 32rpx rgba(255, 107, 107, 0.2);
}

.summary-emoji {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}

.summary-title {
  font-size: 40rpx;
  color: #FFFFFF;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.avg-score-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.04);
}

.avg-label {
  font-size: 26rpx;
  color: #B2BEC3;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  display: block;
  margin-bottom: 16rpx;
}

.avg-number {
  font-size: 80rpx;
  font-weight: 900;
  color: #FF6B6B;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  line-height: 1;
}

.results-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 48rpx;
}

.result-item {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.result-round {
  font-size: 24rpx;
  color: #B2BEC3;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.result-score {
  font-size: 32rpx;
  font-weight: 900;
}

.text-green { color: #10AC84; }
.text-orange { color: #FF9F43; }
.text-red { color: #FF6B6B; }

.result-original {
  font-size: 28rpx;
  color: #2D3436;
  font-weight: 600;
  line-height: 1.6;
  display: block;
  margin-bottom: 8rpx;
}

.result-spoken {
  font-size: 24rpx;
  color: #B2BEC3;
  font-weight: 500;
  line-height: 1.5;
  display: block;
}

.result-feedback-box {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #DFE6E9;
}

.feedback-label {
  font-size: 22rpx;
  color: #FF9F43;
  font-weight: 700;
  margin-right: 8rpx;
}

.result-feedback {
  font-size: 24rpx;
  color: #636E72;
  font-style: italic;
}

/* ========== Buttons ========== */
.btn-listen {
  background: linear-gradient(135deg, #FF6B6B, #FF9F43) !important;
  border: none !important;
  height: 100rpx !important;
  box-shadow: 0 16rpx 32rpx rgba(255, 107, 107, 0.3) !important;
}

.btn-stop {
  background: #EE5253 !important;
  border: none !important;
  height: 88rpx !important;
  padding: 0 48rpx !important;
  box-shadow: 0 12rpx 24rpx rgba(238, 82, 83, 0.3) !important;
}

.btn-primary {
  background: linear-gradient(135deg, #FF6B6B, #FF9F43) !important;
  border: none !important;
  height: 96rpx !important;
  box-shadow: 0 16rpx 32rpx rgba(255, 107, 107, 0.3) !important;
}

.btn-retry {
  background: #FFFFFF !important;
  border: 4rpx solid #FF6B6B !important;
  height: 96rpx !important;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04) !important;
  margin-bottom: 24rpx !important;
}

.btn-secondary {
  background: #FFFFFF !important;
  border: 4rpx solid #FF6B6B !important;
  height: 96rpx !important;
  box-shadow: 0 16rpx 32rpx rgba(0, 0, 0, 0.04) !important;
}

.btn-text-white {
  color: #FFFFFF;
  font-weight: 800;
  font-size: 32rpx;
  letter-spacing: 2rpx;
}

.btn-text-coral {
  color: #FF6B6B;
  font-weight: 800;
  font-size: 32rpx;
  letter-spacing: 2rpx;
}

.action-buttons {
  display: flex;
  gap: 32rpx;
  margin-top: 16rpx;
}

.flex-1 {
  flex: 1;
}

/* ========== Animations ========== */
@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.1); opacity: 0.7; }
}
