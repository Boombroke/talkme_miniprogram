<wxs src="../../utils/score.wxs" module="scoreHelper" />
<view class="shadow-page">
  <nav-bar title="影子跟读" />

  <!-- Round Indicator -->
  <view class="round-indicator" wx:if="{{stage !== 'summary'}}">
    <view class="round-dots">
      <view
        class="round-dot {{index < currentIndex ? 'done' : (index === currentIndex ? 'active' : '')}}"
        wx:for="{{sentences}}"
        wx:key="index"
      ></view>
    </view>
    <text class="round-text">{{currentIndex + 1}} / {{sentences.length}}</text>
  </view>

  <!-- ===== READY Stage ===== -->
  <view class="stage-ready" wx:if="{{stage === 'ready'}}">
    <view class="sentence-card">
      <text class="quote-mark left">"</text>
      <view class="sentence-overlay">
        <text class="overlay-icon">🔊</text>
        <text class="overlay-hint">Tap to Listen</text>
      </view>
      <text class="quote-mark right">"</text>
    </view>
    <van-button
      round
      block
      custom-class="btn-listen"
      bind:click="playSentence"
    >
      <text class="btn-text-white">🎧 Listen</text>
    </van-button>
  </view>

  <!-- ===== LISTENING Stage ===== -->
  <view class="stage-listening" wx:elif="{{stage === 'listening'}}">
    <view class="sentence-card revealed">
      <text class="quote-mark left">"</text>
      <text class="sentence-text">{{currentSentence}}</text>
      <text class="quote-mark right">"</text>
    </view>
    <view class="speaker-anim">
      <view class="pulse-ring ring1"></view>
      <view class="pulse-ring ring2"></view>
      <view class="pulse-ring ring3"></view>
      <view class="speaker-icon">🔊</view>
    </view>
    <text class="stage-hint">Playing audio...</text>
  </view>

  <!-- ===== RECORDING Stage ===== -->
  <view class="stage-recording" wx:elif="{{stage === 'recording'}}">
    <view class="sentence-card revealed">
      <text class="quote-mark left">"</text>
      <text class="sentence-text">{{currentSentence}}</text>
      <text class="quote-mark right">"</text>
    </view>
    <view class="recording-section">
      <text class="recording-title">Now Your Turn 🎤</text>
      <view class="mic-anim">
        <view class="mic-pulse p1"></view>
        <view class="mic-pulse p2"></view>
        <text class="mic-icon">🎙️</text>
      </view>
      <text class="record-timer">{{recordTime}}s</text>
      <van-button
        round
        custom-class="btn-stop"
        bind:click="stopRecording"
      >
        <text class="btn-text-white">⏹ Stop Recording</text>
      </van-button>
    </view>
  </view>

  <!-- ===== COMPARING Stage ===== -->
  <view class="stage-comparing" wx:elif="{{stage === 'comparing'}}">
    <view class="loading-wrap">
      <van-loading size="48rpx" color="#FF6B6B" />
      <text class="loading-text">对比中...</text>
    </view>
  </view>

  <!-- ===== RESULT Stage ===== -->
  <view class="stage-result" wx:elif="{{stage === 'result'}}">

    <!-- No Speech Detected -->
    <view wx:if="{{noSpeechDetected}}" class="no-speech-box">
      <text class="no-speech-icon">😶</text>
      <text class="no-speech-text">未检测到有效英语语音，请重新录音</text>
      <van-button
        round
        block
        custom-class="btn-retry"
        bind:click="retryCurrentSentence"
      >
        <text class="btn-text-coral">🔄 Retry This Sentence</text>
      </van-button>
    </view>

    <!-- Normal Result (similarity > 0) -->
    <block wx:else>
      <!-- Confetti Animation for High Score -->
      <view class="confetti-container" wx:if="{{similarity >= 80}}">
        <view class="confetti-piece" wx:for="{{20}}" wx:key="index"></view>
      </view>

      <!-- Encouragement for Low Score -->
      <view class="encouragement-box" wx:if="{{similarity < 60}}">
        <text class="encouragement-text">Don't give up! Keep practicing! 💪</text>
      </view>

      <!-- Similarity Score -->
      <view class="score-circle {{scoreHelper.getScoreClass(similarity)}}">
        <text class="score-number">{{similarity}}</text>
        <text class="score-percent">%</text>
      </view>
      <text class="score-label">Similarity</text>

      <van-progress
        percentage="{{similarity}}"
        stroke-width="8"
        color="{{scoreHelper.getScoreColor(similarity)}}"
        track-color="#F0F0F0"
        custom-class="progress-bar"
      />

      <!-- Comparison -->
      <view class="compare-section">
        <view class="compare-item">
          <view class="compare-label-row">
            <view class="compare-label">
              <text class="compare-icon">📖</text>
              <text>Original</text>
            </view>
            <view class="play-btn-small {{playingTTSId === 'original-' + currentIndex ? 'playing' : ''}}" bindtap="playFeedbackTTS" data-text="{{currentSentence}}" data-type="original">
              🔊
            </view>
          </view>
          <text class="compare-text original">{{currentSentence}}</text>
        </view>
        <view class="compare-item">
          <view class="compare-label">
            <text class="compare-icon">🗣️</text>
            <text>You Said</text>
          </view>
          <text class="compare-text spoken">{{userText}}</text>
        </view>
        
        <!-- Feedback -->
        <view class="compare-item" wx:if="{{roundResults[roundResults.length - 1].feedback}}">
          <view class="compare-label-row">
            <view class="compare-label">
              <text class="compare-icon">💡</text>
              <text>Feedback</text>
            </view>
            <view class="play-btn-small {{playingTTSId === 'feedback-' + currentIndex ? 'playing' : ''}}" bindtap="playFeedbackTTS" data-text="{{roundResults[roundResults.length - 1].feedback}}" data-type="feedback">
              🔊
            </view>
          </view>
          <text class="compare-text feedback-text">{{roundResults[roundResults.length - 1].feedback}}</text>
        </view>
      </view>

      <van-button
        wx:if="{{similarity < 80}}"
        round
        block
        plain
        custom-class="btn-retry"
        bind:click="retryCurrentSentence"
      >
        <text class="btn-text-coral">🔄 Retry This Sentence</text>
      </van-button>

      <van-button
        round
        block
        custom-class="btn-primary"
        bind:click="nextRound"
      >
        <text class="btn-text-white">{{currentIndex + 1 >= sentences.length ? '📊 See Summary' : '➡️ Next Sentence'}}</text>
      </van-button>
    </block>
  </view>

  <!-- ===== SUMMARY Stage ===== -->
  <view class="stage-summary" wx:elif="{{stage === 'summary'}}">
    <view class="summary-banner">
      <text class="summary-emoji">{{averageSimilarity >= 80 ? '🎉' : (averageSimilarity >= 60 ? '👍' : '💪')}}</text>
      <text class="summary-title">Practice Complete!</text>
    </view>

    <!-- Average Score -->
    <view class="avg-score-card">
      <text class="avg-label">Average Similarity</text>
      <text class="avg-number">{{averageSimilarity}}%</text>
    </view>

    <!-- Round Results -->
    <view class="results-list">
      <view class="result-item" wx:for="{{roundResults}}" wx:key="index">
        <view class="result-header">
          <text class="result-round">Round {{index + 1}}</text>
          <text class="result-score {{item.scoreClass}}">{{item.similarity}}%</text>
        </view>
        <text class="result-original">{{item.original}}</text>
        <text class="result-spoken">You: {{item.spoken}}</text>
        <view class="result-feedback-box" wx:if="{{item.feedback}}">
          <text class="feedback-label">Feedback:</text>
          <text class="result-feedback">{{item.feedback}}</text>
        </view>
      </view>
    </view>

    <view class="action-buttons">
      <van-button round block custom-class="btn-primary flex-1" bind:click="tryAgain">
        <text class="btn-text-white">🔄 Try Again</text>
      </van-button>
      <van-button round block plain custom-class="btn-secondary flex-1" bind:click="goHome">
        <text class="btn-text-coral">🏠 Home</text>
      </van-button>
    </view>
  </view>

</view>
