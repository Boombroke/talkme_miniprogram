.history-page {
  min-height: 100vh;
  background: #F8F9FA;
  padding-bottom: 48rpx;
}

.search-wrapper {
  background: #FFFFFF;
  padding: 16rpx 24rpx 8rpx;
}

/* Override Vant Search */
.custom-search .van-search {
  padding: 0 !important;
}

.custom-search .van-search__content {
  background-color: #FFF0E6 !important;
  border-radius: 40rpx !important;
}

/* Filter Tabs */
.filter-container {
  background: #FFFFFF;
  padding: 16rpx 24rpx 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.filter-scroll {
  width: 100%;
}

.filter-tabs {
  display: flex;
  gap: 12rpx;
  padding: 0 4rpx;
}

.tab {
  flex-shrink: 0;
  text-align: center;
  padding: 14rpx 28rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  color: #636E72;
  background: #F8F9FA;
  font-weight: 700;
  white-space: nowrap;
}

.tab.active {
  background: linear-gradient(135deg, #FF6B6B, #FF9F43);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

/* Conversation List & Cards */
.conversation-list {
  padding: 32rpx 24rpx;
}

.conversation-card {
  background: #FFFFFF;
  border-radius: 40rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.06);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  border: 1rpx solid rgba(255, 107, 107, 0.05);
}

.conversation-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.04);
}

.conv-cell {
  padding: 40rpx !important;
  background: transparent !important;
}

.conv-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.conv-tags {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.mode-tag, .scene-tag {
  font-weight: 700 !important;
  padding: 6rpx 20rpx !important;
  font-size: 20rpx !important;
}

.conv-time {
  font-size: 22rpx;
  color: #B2BEC3;
  font-weight: 600;
}

.conv-content {
  margin-top: 8rpx;
}

.conv-preview {
  font-size: 30rpx;
  color: #2D3436;
  line-height: 1.6;
  margin-bottom: 32rpx;
  font-weight: 500;
}

.conv-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 2rpx dashed #FFF0E6;
}

.footer-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.chat-icon {
  font-size: 28rpx;
}

.conv-count {
  font-size: 24rpx;
  color: #636E72;
  font-weight: 600;
}

.score-tag {
  font-weight: 700 !important;
  font-size: 22rpx !important;
  padding: 8rpx 24rpx !important;
}

/* States */
.empty-wrap {
  padding-top: 120rpx;
}

.custom-empty .van-empty__image {
  width: 240rpx;
  height: 240rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 48rpx 0;
}

.no-more-wrap {
  margin-top: 24rpx;
}

/* Animations */
.animate-fade-in {
  animation: fadeIn 0.5s ease backwards;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}