/* Voice Button - Modern Aesthetic */

.voice-btn-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 16rpx 0;
  position: relative;
}

.voice-btn {
  width: 100%;
  height: 100rpx;
  background: #FFFFFF;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); /* Springy transition */
  z-index: 2;
}

.voice-btn:active:not(.disabled) {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.voice-btn.recording {
  background: linear-gradient(135deg, #FF6B6B, #FF9F43);
  box-shadow: 0 16rpx 40rpx rgba(255, 107, 107, 0.3);
  transform: scale(1.02);
}

.voice-btn.recording:active {
  transform: scale(0.98);
}

.voice-btn.disabled {
  opacity: 0.5;
  background: #F8F9FA;
  box-shadow: none;
}

/* Background pulsing ring during recording */
.recording-ring {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100%;
  height: 100%;
  border-radius: 50rpx;
  background: rgba(255, 107, 107, 0.2);
  z-index: -1;
  animation: ring-pulse 1.5s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  pointer-events: none;
}

@keyframes ring-pulse {
  0% { transform: translate(-50%, -50%) scale(1); opacity: 0.8; }
  100% { transform: translate(-50%, -50%) scale(1.15); opacity: 0; }
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  position: relative;
  z-index: 3;
}

.btn-icon {
  font-size: 40rpx;
  line-height: 1;
}

.btn-text {
  font-size: 32rpx;
  color: #2D3436;
  font-weight: bold;
  letter-spacing: 2rpx;
}

.recording-text {
  color: #FFFFFF;
}

/* Inner glow for text/icon during recording */
.recording-glow {
  position: absolute;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, rgba(255,255,255,0) 70%);
  animation: inner-pulse 2s ease-in-out infinite alternate;
  pointer-events: none;
  z-index: -1;
}

@keyframes inner-pulse {
  0% { opacity: 0.3; transform: scale(0.8); }
  100% { opacity: 1; transform: scale(1.2); }
}

/* Waveform visualization */
.waveform { display: flex; align-items: center; justify-content: center; gap: 6rpx; margin-left: 16rpx; height: 50rpx; }
.wave-bar { width: 6rpx; background: rgba(255,255,255,0.7); border-radius: 3rpx; transition: height 0.1s ease; min-height: 10rpx; }
