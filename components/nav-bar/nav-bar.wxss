.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF9F43 100%);
}
.nav-content {
  display: flex;
  align-items: center;
  padding-left: 16rpx;
  box-sizing: border-box;
}

/* Standard mode: back + title */
.nav-left {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
}
.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.nav-back:active {
  opacity: 0.5;
}
.nav-back-arrow {
  font-size: 44rpx;
  color: #FFFFFF;
  font-weight: 300;
  margin-top: -4rpx;
}
.nav-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: -0.3px;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
