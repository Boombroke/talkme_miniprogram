.score-card {
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(255, 107, 107, 0.08);
}

/* Animations */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-fade-in-up {
  animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.score-header {
  display: flex;
  justify-content: center;
  margin-bottom: 56rpx;
  position: relative;
}

.score-header::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 160rpx;
  background: radial-gradient(circle, rgba(255, 107, 107, 0.1) 0%, rgba(255, 159, 67, 0) 70%);
  z-index: 0;
  border-radius: 50%;
}

.ring-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  position: relative;
  z-index: 1;
}

.score-number {
  font-size: 72rpx;
  font-weight: 800;
  color: #2D3436;
  line-height: 1;
  letter-spacing: -2rpx;
}

.score-label {
  font-size: 24rpx;
  color: #B2BEC3;
  margin-top: 8rpx;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.dimensions {
  margin-top: 24rpx;
}

.dimension-item {
  margin-bottom: 40rpx;
}

.dimension-item:last-child {
  margin-bottom: 24rpx;
}

.dim-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 16rpx;
}

.dim-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #636E72;
}

.dim-score {
  font-size: 32rpx;
  font-weight: 800;
}

/* Color utility classes matching the design system */
.text-coral { color: #FF6B6B; }
.text-orange { color: #FF9F43; }
.text-teal { color: #10AC84; }
.text-yellow { color: #FECA57; }
.text-danger { color: #EE5253; }

/* Vant Collapse Overrides */
.collapse-custom .van-cell {
  background: transparent !important;
  padding: 16rpx 0 !important;
  font-weight: 600 !important;
  color: #636E72 !important;
}

.van-collapse-item__content {
  padding: 0 !important;
  background-color: transparent !important;
}

.detail-content {
  margin-top: 16rpx;
  padding: 24rpx;
  background: #F8F9FA;
  border-radius: 24rpx;
}

.detail-section {
  margin-bottom: 32rpx;
}

.detail-section:last-child {
  margin-bottom: 0;
}

.detail-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  display: block;
}

.issue-item {
  display: flex;
  padding: 8rpx 0;
  align-items: flex-start;
}

.issue-dot {
  margin-right: 16rpx;
  font-size: 32rpx;
  line-height: 40rpx;
}

.issue-text {
  font-size: 26rpx;
  color: #2D3436;
  flex: 1;
  line-height: 1.6;
  font-weight: 500;
}