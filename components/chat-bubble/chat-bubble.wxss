/* Chat Bubble - Modern Aesthetic */

.bubble-wrapper {
  display: flex;
  margin-bottom: 40rpx;
  padding: 0 32rpx;
  align-items: flex-end; /* Align to bottom for modern chat feel */
}

.bubble-left {
  flex-direction: row;
  justify-content: flex-start;
}

.bubble-right {
  flex-direction: row;
  justify-content: flex-end;
}

/* Avatars - rounded square */
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.ai-avatar {
  background: #FFFFFF;
  margin-right: 16rpx;
  border: 2rpx solid rgba(0,0,0,0.02);
}

.user-avatar {
  background: linear-gradient(135deg, #FF6B6B, #FF9F43);
  margin-left: 16rpx;
}

.avatar-text {
  font-size: 40rpx;
  line-height: 1;
}

.avatar-img-full {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  display: block;
}

/* Bubble body wrapper */
.bubble-body {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  max-width: 75%;
}

.bubble-right-body {
  align-items: flex-end;
}

.bubble-left-body {
  align-items: flex-start;
}

/* Bubble */
.bubble {
  padding: 24rpx 32rpx;
  word-break: break-all;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.bubble-user {
  background: linear-gradient(135deg, #FF6B6B, #FF9F43);
  border-radius: 32rpx 32rpx 8rpx 32rpx;
}

.bubble-ai {
  background-color: #FFFFFF;
  border-radius: 32rpx 32rpx 32rpx 8rpx;
}

.bubble-content {
  font-size: 32rpx;
  line-height: 1.6;
  font-weight: 500;
}

.bubble-user .bubble-content {
  color: #FFFFFF;
}

.bubble-ai .bubble-content {
  color: #2D3436;
}

/* Streaming cursor */
.bubble-cursor {
  display: inline;
  color: #FF6B6B;
  animation: blink 0.8s infinite;
  font-weight: bold;
  margin-left: 4rpx;
}

@keyframes blink {
  0%, 50% { opacity: 1; }
  51%, 100% { opacity: 0; }
}

/* Typing indicator */
.typing-dots { display: flex; align-items: center; gap: 8rpx; padding: 8rpx 0; }
.typing-dot { width: 12rpx; height: 12rpx; background: #FF6B6B; border-radius: 50%; animation: typingBounce 1.4s infinite ease-in-out both; }
.typing-dot:nth-child(1) { animation-delay: -0.32s; }
.typing-dot:nth-child(2) { animation-delay: -0.16s; }
@keyframes typingBounce { 0%, 80%, 100% { transform: scale(0); opacity: 0.4; } 40% { transform: scale(1); opacity: 1; } }

/* Audio footer */
.bubble-footer {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
}

.audio-btn {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 24rpx;
  gap: 12rpx;
  background: rgba(16, 172, 132, 0.08);
  border-radius: 32rpx;
  transition: all 0.2s ease;
}

.audio-btn:active {
  transform: scale(0.95);
  background: rgba(16, 172, 132, 0.15);
}

.audio-icon {
  font-size: 28rpx;
}

.is-playing .audio-icon {
  animation: bounce-icon 1s ease-in-out infinite alternate;
}

@keyframes bounce-icon {
  from { transform: translateY(0); }
  to { transform: translateY(-4rpx); }
}

.audio-text {
  font-size: 24rpx;
  color: #10AC84;
  font-weight: bold;
}

/* Loading Pulse */
.loading-pulse {
  display: flex;
  align-items: center;
  gap: 4rpx;
  height: 40rpx; /* Match icon height */
}

.dot {
  color: #10AC84;
  font-weight: bold;
  font-size: 28rpx;
  animation: typing 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes typing {
  0%, 80%, 100% { transform: scale(0); opacity: 0.3; }
  40% { transform: scale(1); opacity: 1; }
}

/* Translation section */
.translate-section { margin-top: 12rpx; }
.translate-btn {
  display: inline-flex; align-items: center; gap: 8rpx;
  padding: 6rpx 20rpx; background: rgba(255,107,107,0.08);
  border-radius: 24rpx; transition: all 0.2s;
}
.translate-btn:active { transform: scale(0.95); background: rgba(255,107,107,0.15); }
.translate-icon { font-size: 24rpx; }
.translate-label { font-size: 22rpx; color: #FF6B6B; font-weight: 600; }
.translate-content {
  margin-top: 12rpx; padding: 16rpx 20rpx;
  background: rgba(255,107,107,0.04); border-radius: 16rpx;
  border-left: 4rpx solid #FF6B6B;
}
.translate-text { font-size: 26rpx; color: #636E72; line-height: 1.6; }

/* Correction hint */
.correction-hint {
  display: flex; align-items: center; gap: 8rpx;
  margin-top: 8rpx; padding: 8rpx 16rpx;
  background: rgba(254, 202, 87, 0.15); border-radius: 16rpx;
}
.correction-icon { font-size: 22rpx; }
.correction-text { font-size: 22rpx; color: #636E72; font-weight: 500; }

/* Retry hint for failed messages */
.retry-hint {
  margin-top: 12rpx;
  padding: 8rpx 20rpx;
  background: rgba(255, 107, 107, 0.08);
  border-radius: 16rpx;
  display: inline-flex;
  align-items: center;
}

.retry-hint:active {
  background: rgba(255, 107, 107, 0.18);
}

.retry-text {
  font-size: 24rpx;
  color: #FF6B6B;
  font-weight: 500;
}

/* ==================== Voice Bubble ==================== */
.voice-bubble {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 28rpx;
  min-width: 140rpx;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  transition: all 0.25s ease;
}

.voice-bubble:active {
  transform: scale(0.97);
}

.voice-bubble-user {
  background: linear-gradient(135deg, #FF6B6B, #FF9F43);
  justify-content: space-between;
}

.voice-bubble-ai {
  background: #FFFFFF;
  justify-content: flex-start;
  border: 2rpx solid rgba(255, 107, 107, 0.08);
}

.voice-bubble-playing {
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.25);
}

.voice-icon {
  font-size: 32rpx;
  line-height: 1;
  flex-shrink: 0;
}

.voice-bubble-ai .voice-icon {
  color: #FF6B6B;
}

.voice-duration {
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.voice-bubble-user .voice-duration {
  color: #FFFFFF;
}

.voice-bubble-ai .voice-duration {
  color: #FF6B6B;
}

/* Voice wave animation bars */
.voice-wave {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex: 1;
  justify-content: center;
  height: 32rpx;
}

.voice-wave-bar {
  width: 6rpx;
  height: 12rpx;
  border-radius: 3rpx;
  background: rgba(255, 255, 255, 0.7);
}

.voice-bubble-ai .voice-wave-bar {
  background: rgba(255, 107, 107, 0.5);
}

.voice-wave.is-playing .voice-wave-bar {
  animation: voiceWave 1s ease-in-out infinite;
}

.voice-wave.is-playing .voice-wave-bar:nth-child(1) { animation-delay: 0s; }
.voice-wave.is-playing .voice-wave-bar:nth-child(2) { animation-delay: 0.2s; }
.voice-wave.is-playing .voice-wave-bar:nth-child(3) { animation-delay: 0.4s; }

@keyframes voiceWave {
  0%, 100% { height: 12rpx; opacity: 0.6; }
  50% { height: 28rpx; opacity: 1; }
}

/* Voice row: bubble + action buttons on one line */
.voice-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  max-width: 100%;
}

.voice-row-user {
  flex-direction: row-reverse;
}

.voice-row-ai {
  flex-direction: row;
}

/* Voice action buttons (转文字 / 翻译) */
.voice-actions {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
}

.voice-action-btn {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  background: rgba(255, 107, 107, 0.08);
  border-radius: 24rpx;
  transition: all 0.2s;
}

.voice-action-btn:active {
  transform: scale(0.95);
  background: rgba(255, 107, 107, 0.18);
}

.voice-action-icon {
  font-size: 22rpx;
}

.voice-action-label {
  font-size: 22rpx;
  color: #FF6B6B;
  font-weight: 600;
}

/* Voice transcript reveal panel */
.voice-transcript {
  margin-top: 12rpx;
  padding: 16rpx 20rpx;
  background: rgba(255, 159, 67, 0.08);
  border-radius: 16rpx;
  border-left: 4rpx solid #FF9F43;
  max-width: 100%;
}

.voice-transcript-text {
  font-size: 26rpx;
  color: #2D3436;
  line-height: 1.6;
}
.voice-transcript-text.is-empty {
  color: #B2BEC3;
  font-style: italic;
}
