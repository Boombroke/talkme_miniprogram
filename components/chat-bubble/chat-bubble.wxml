<view class="bubble-wrapper {{role === 'user' ? 'bubble-right' : 'bubble-left'}}">
  <view class="chat-menu-mask" wx:if="{{showMenu}}" catchtap="closeMenu"></view>
  <!-- AI Avatar -->
  <view class="avatar ai-avatar" wx:if="{{role === 'assistant'}}">
    <text class="avatar-text">{{aiAvatarEmoji || '🤖'}}</text>
  </view>

  <view class="bubble-body {{role === 'user' ? 'bubble-right-body' : 'bubble-left-body'}}">
    <view class="bubble-menu {{role === 'user' ? 'bubble-menu-user' : 'bubble-menu-ai'}}" wx:if="{{showMenu}}" catchtap="onMenuTap">
      <view class="bubble-menu-item" wx:if="{{role === 'assistant'}}" catchtap="onMenuTranslate">转中文</view>
      <view class="bubble-menu-item" wx:if="{{role === 'assistant'}}" catchtap="onMenuTTS">播放</view>
      <view class="bubble-menu-item" wx:if="{{role === 'assistant'}}" catchtap="onMenuCollect">收藏</view>
      <view class="bubble-menu-item" catchtap="onMenuCopy">复制</view>
    </view>

    <!-- VOICE MESSAGE BRANCH -->
    <block wx:if="{{type === 'voice'}}">
      <view class="voice-row {{role === 'user' ? 'voice-row-user' : 'voice-row-ai'}}">
        <view class="voice-bubble {{role === 'user' ? 'voice-bubble-user' : 'voice-bubble-ai'}} {{isVoicePlaying ? 'voice-bubble-playing' : ''}}"
              style="width: {{isTyping ? 180 : voiceWidth}}rpx;"
              bindtap="onTapVoice"
              catchlongpress="onLongPress">
          <view class="typing-dots" wx:if="{{isTyping}}">
            <view class="typing-dot"></view>
            <view class="typing-dot"></view>
            <view class="typing-dot"></view>
          </view>
          <block wx:elif="{{role === 'user'}}">
            <text class="voice-duration">{{duration}}″</text>
            <view class="voice-wave {{isVoicePlaying ? 'is-playing' : ''}}">
              <view class="voice-wave-bar"></view>
              <view class="voice-wave-bar"></view>
              <view class="voice-wave-bar"></view>
            </view>
            <text class="voice-icon">🔊</text>
          </block>
          <block wx:else>
            <text class="voice-icon">🔊</text>
            <view class="voice-wave {{isVoicePlaying ? 'is-playing' : ''}}">
              <view class="voice-wave-bar"></view>
              <view class="voice-wave-bar"></view>
              <view class="voice-wave-bar"></view>
            </view>
            <text class="voice-duration">{{duration}}″</text>
          </block>
        </view>

        <view class="voice-actions" wx:if="{{!isTyping && role !== 'assistant'}}">
          <view class="voice-action-btn" bindtap="onTapTranscript">
            <text class="voice-action-icon">📝</text>
            <text class="voice-action-label">{{showTranscript ? '收起' : '转文字'}}</text>
          </view>
          <view class="voice-action-btn" bindtap="onTapTranslate">
            <text class="voice-action-icon">🌐</text>
            <text class="voice-action-label">{{translating ? '翻译中...' : (showTranslation ? '收起' : '翻译')}}</text>
          </view>
        </view>
      </view>

      <view class="voice-transcript" wx:if="{{showTranscript}}">
        <text class="voice-transcript-text {{!content ? 'is-empty' : ''}}">{{content || '好像什么也没说…'}}</text>
      </view>

      <view class="translate-content" wx:if="{{showTranslation && translatedText}}">
        <text class="translate-text">{{translatedText}}</text>
      </view>

      <!-- Correction hint for AI voice messages -->
      <view class="correction-hint" wx:if="{{correction && role === 'assistant'}}">
        <text class="correction-icon">✏️</text>
        <text class="correction-text">{{correction}}</text>
      </view>
      <!-- Retry hint for failed messages -->
      <view class="retry-hint" wx:if="{{sendFailed}}" bindtap="onRetry">
        <text class="retry-text">⚠️ 发送失败，点击重试</text>
      </view>
    </block>

    <!-- TEXT MESSAGE BRANCH (original behavior) -->
    <block wx:else>
      <view class="bubble {{role === 'user' ? 'bubble-user' : 'bubble-ai'}}" catchlongpress="onLongPress">
        <view class="typing-dots" wx:if="{{isTyping}}">
          <view class="typing-dot"></view>
          <view class="typing-dot"></view>
          <view class="typing-dot"></view>
        </view>
        <text class="bubble-content" wx:if="{{!isTyping}}">{{displayContent || content}}</text>
        <view class="bubble-cursor" wx:if="{{!isTyping && isStreaming && displayContent.length < content.length}}">|</view>

        <!-- Translation result for AI messages; actions live in the long-press menu -->
        <view class="translate-section" wx:if="{{role === 'assistant' && showTranslation && translatedText}}">
          <view class="translate-content" wx:if="{{showTranslation && translatedText}}">
            <text class="translate-text">{{translatedText}}</text>
          </view>
        </view>
      </view>
      <!-- Correction hint for AI messages -->
      <view class="correction-hint" wx:if="{{correction && role === 'assistant'}}">
        <text class="correction-icon">✏️</text>
        <text class="correction-text">{{correction}}</text>
      </view>
      <!-- Retry hint for failed messages -->
      <view class="retry-hint" wx:if="{{sendFailed}}" bindtap="onRetry">
        <text class="retry-text">⚠️ 发送失败，点击重试</text>
      </view>
    </block>
  </view>

  <!-- User Avatar：登录后用微信头像，游客显示 😊 -->
  <view class="avatar user-avatar" wx:if="{{role === 'user'}}">
    <image
      wx:if="{{userAvatarUrl}}"
      class="avatar-img-full"
      src="{{userAvatarUrl}}"
      mode="aspectFill"
    />
    <text wx:else class="avatar-text">😊</text>
  </view>
</view>
